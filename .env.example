# ============================================
# LexFlowAI - Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env com valores reais!

# === FRONTEND (Variáveis públicas - prefixo VITE_) ===
VITE_SUPABASE_PROJECT_ID="seu-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="sua-anon-key"
VITE_SUPABASE_URL="https://seu-projeto.supabase.co"

# ============================================
# IMPORTANTE: As variáveis acima são PÚBLICAS
# e seguras para o frontend (anon key).
#
# Chaves privadas como SERVICE_ROLE_KEY devem
# ser configuradas APENAS no backend via:
# Lovable Cloud > Secrets
# ============================================
